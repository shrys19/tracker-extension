{
  "manifest_version": 3,
  "name": "Website Time Tracker",
  "version": "1.1",
  "description": "Track time spent on selected websites",
  "permissions": [
    "tabs",
    "storage",
    "windows",
    "idle",
    "alarms",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}